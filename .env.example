# Supabase (projet région EU)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Serveur uniquement — jamais exposée au client
SUPABASE_SERVICE_ROLE_KEY=

# IA — Vercel AI SDK. Un modèle = « provider:model ».
# Fournisseurs supportés : anthropic, openai, google, mistral (clé requise par fournisseur utilisé).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
MISTRAL_API_KEY=

# Modèles par niveau d'usage (défauts Anthropic si absents)
LLM_MODEL=anthropic:claude-sonnet-5
LLM_MODEL_PREMIUM=anthropic:claude-opus-4-8
LLM_MODEL_LIGHT=anthropic:claude-haiku-4-5-20251001

# Chiffrement des tokens OAuth des connecteurs (32 octets, base64)
# Générer : openssl rand -base64 32
CONNECTOR_TOKEN_ENCRYPTION_KEY=
